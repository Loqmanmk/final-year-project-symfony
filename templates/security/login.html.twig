{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="container auth-wrap">
    <div class="auth-panel">
        <p class="eyebrow">Compte client</p>
        <h1>Connexion</h1>

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="mb-3">
                <label class="form-label" for="username">Email</label>
                <input class="form-control" type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Mot de passe</label>
                <input class="form-control" type="password" name="_password" id="password" autocomplete="current-password" required>
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button class="btn btn-primary w-100" type="submit">Se connecter</button>
        </form>

        <p class="auth-note">Compte demo : demo@example.com / password</p>
        <a href="{{ path('app_register') }}">Creer un compte</a>
    </div>
</section>
{% endblock %}
